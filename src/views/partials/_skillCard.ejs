<%#
  SkillCard 单个技能包
  props: pack { id, code, name, rarity, level, tags, cost, locked, equipped }, index
%>
<%
  const RARITY_COLOR = { T1: '#7e8a96', T2: '#4dd0ff', T3: '#7cffb2', T4: '#ffb547', T5: '#ff7eb6', T6: '#ff4d5e' };
  var color = RARITY_COLOR[pack.rarity] || '#7e8a96';
  var delay = Math.min(index * 18, 540);
  const cls = ['card'];
  if (pack.locked) cls.push('is-locked');
  if (pack.equipped) cls.push('is-equipped');
%>
<button type="button"
        class="<%= cls.join(' ') %>"
        data-pack-id="<%= pack.id %>"
        data-rarity="<%= pack.rarity %>"
        data-level="<%= pack.level %>"
        style="--card-rarity: <%= color %>; animation-delay: <%= delay %>ms;">
  <span class="card__corner card__corner--tl"></span>
  <span class="card__corner card__corner--br"></span>
  <div class="card__top">
    <span class="card__rarity" style="color: <%= color %>;"><%= pack.rarity %></span>
    <div class="card__top-right">
      <% if (pack.equipped) { %>
        <span class="card__zap" title="已装备">
          <svg viewBox="0 0 16 16" width="9" height="9" fill="currentColor">
            <path d="M9 1 L3 9 L7 9 L6 15 L13 6 L9 6 Z" />
          </svg>
        </span>
      <% } %>
      <% if (pack.locked) { %>
        <svg class="card__lock" viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="#ff4d5e" stroke-width="1.5">
          <rect x="3" y="7" width="10" height="7" />
          <path d="M5 7 L5 5 C5 3 6 1 8 1 C10 1 11 3 11 5 L11 7" />
        </svg>
      <% } %>
    </div>
  </div>
  <div class="card__code-id"><%= pack.id %></div>
  <div class="card__code" title="<%= pack.code %>"><%= pack.code %></div>
  <div class="card__bottom">
    <div class="card__lv">
      <span class="card__lv-num"><%= pad2(pack.level) %></span>
      <span class="card__lv-max">/ 90</span>
    </div>
    <div class="card__lv-bar">
      <div class="card__lv-bar-fill" style="width: <%= (pack.level / 90 * 100).toFixed(0) %>%; background: <%= color %>;"></div>
    </div>
  </div>
  <% if (pack.locked) { %>
    <div class="card__lock-overlay">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#ff4d5e" stroke-width="1.5" opacity="0.4">
        <rect x="5" y="11" width="14" height="9" />
        <path d="M8 11 L8 8 C8 5.5 10 4 12 4 C14 4 16 5.5 16 8 L16 11" />
      </svg>
    </div>
  <% } %>
</button>
