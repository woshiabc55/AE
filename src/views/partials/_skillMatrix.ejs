<%#
  SkillMatrix 中央矩阵
  props: active { id, code, name, packs, capacity }
%>
<main class="matrix" id="matrix">
  <div class="matrix__toolbar">
    <div class="matrix__title">
      <span class="matrix__title-sub">MATRIX //</span>
      <span class="matrix__title-code"><%= active.code %></span>
      <span class="matrix__title-name">「<%= active.name %>」</span>
    </div>
    <div class="matrix__filters" id="rarity-filter">
      <% ['ALL', 'T2', 'T3', 'T4', 'T5', 'T6'].forEach(function(r) { %>
        <button type="button" class="matrix__filter <%= r === 'ALL' ? 'is-on' : '' %>" data-rarity="<%= r %>"><%= r %></button>
      <% }) %>
    </div>
    <div class="matrix__search">
      <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="7" cy="7" r="5" />
        <line x1="11" y1="11" x2="14" y2="14" />
      </svg>
      <input type="text" id="search-input" placeholder="检索代号 / 名称 / 词条…" />
    </div>
    <div class="matrix__actions">
      <button type="button" class="btn btn--ghost" id="btn-select-all">
        <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="12" height="12" />
          <polyline points="5 8 7 10 11 5" />
        </svg>
        <span id="select-all-label">SELECT ALL</span>
      </button>
      <button type="button" class="btn btn--icon" id="btn-invert" title="反选">
        <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 5 L8 1 L14 5 L14 11 L8 15 L2 11 Z" />
          <path d="M11 5 L11 11" />
        </svg>
      </button>
      <button type="button" class="btn btn--ghost" id="btn-export">
        <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8 1 L8 11" />
          <polyline points="4 7 8 11 12 7" />
          <path d="M2 13 L14 13" />
        </svg>
        EXPORT
      </button>
    </div>
  </div>

  <div class="matrix__scroll" id="matrix-scroll">
    <div class="matrix__inner" id="matrix-grid">
      <div class="matrix__meta">
        <span>VISIBLE <span class="matrix__meta-c" id="visible-count"><%= len(active.packs) %></span> / TOTAL <span class="matrix__meta-w"><%= len(active.packs) %></span> · SELECTED <span class="matrix__meta-a" id="selected-count">0</span></span>
        <span class="matrix__meta-hint">
          <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M2 4 L14 4 L14 12 L2 12 Z" />
            <path d="M2 4 L8 8 L14 4" />
          </svg>
          DRAG TO BOX-SELECT · CLICK FOR INSPECT
        </span>
      </div>
      <div class="matrix__grid" id="grid-cards">
        <% for (let i = 0; i < active.packs.length; i++) { %>
          <% const pack = active.packs[i]; %>
          <%- await include('partials/_skillCard', { pack: pack, index: i }) %>
        <% } %>
      </div>
    </div>
    <div class="matrix__marquee" id="marquee"></div>
  </div>
</main>
