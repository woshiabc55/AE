{
  "apiVersion": "1.0.0",
  "service": "pixel-forge-api",
  "senik": {
    "description": "Senik 内容文件夹 — 场景/效果/纹理/模型/配置的持久化存储",
    "structure": {
      "scenes/": "场景配置文件 (.json)",
      "effects/": "效果预设文件 (.json)",
