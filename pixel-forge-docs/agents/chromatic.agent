{
  "//": ".agent — 模块代理文档 | Module Agent Document",

  "format": "agent/1.0",
  "type": "module-agent",

  "id": "chromatic",
  "name": "ChromaticEffect",
  "layer": "effect",
  "version": 1,
  "state": "published",

  "description": "色差效果模块 · RGB通道独立位移 · 模拟镜头色散",

  "interfaces": [
    {
      "name": "render",
      "signature": "render(ctx: CanvasRenderingContext2D, source: ImageData, time: number): void",
      "description": "渲染色差效果"
    }
  ],

  "dependencies": ["agent:eventbus"],

  "lifecycle": ["init", "active", "dispose"],

  "events": {
    "publishes": [],
    "subscribes": ["effect:changed", "param:changed", "animation:frame"]
  },

  "shape3d": {
    "geometry": "dodecahedron",
    "color": "#ffaa00",
    "size": 0.4,
    "position": [2.5, 0, 0]
  }
}
