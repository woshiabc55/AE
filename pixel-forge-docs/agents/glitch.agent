{
  "//": ".agent — 模块代理文档 | Module Agent Document",

  "format": "agent/1.0",
  "type": "module-agent",

  "id": "glitch",
  "name": "GlitchEffect",
  "layer": "effect",
  "version": 1,
  "state": "published",

  "description": "故障效果模块 · 行级位移+色彩偏移+随机块替换",

  "interfaces": [
    {
      "name": "render",
      "signature": "render(ctx: CanvasRenderingContext2D, source: ImageData, time: number): void",
      "description": "渲染故障效果"
    },
    {
      "name": "triggerBurst",
      "signature": "triggerBurst(): void",
      "description": "手动触发一次故障爆发"
    }
  ],

  "dependencies": ["agent:eventbus"],

  "lifecycle": ["init", "active", "dispose"],

  "events": {
    "publishes": [],
    "subscribes": ["effect:changed", "param:changed", "animation:frame"]
  },

  "shape3d": {
    "geometry": "icosahedron",
    "color": "#ff00ff",
    "size": 0.4,
    "position": [1.5, 0, 0]
  }
}
