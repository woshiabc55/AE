{
  "name": "industrial-fantasy",
  "version": "1.0.0",
  "description": "工业仙境 · 文字动画 — Node.js 企业级单页应用",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"tsx watch api/server.ts\"",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "NODE_ENV=production tsx api/server.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.5.0",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
