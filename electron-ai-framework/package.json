{
  "name": "electron-ai-framework",
  "version": "1.0.0",
  "description": "Electron AI Integration Software Framework",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "js-yaml": "^4.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.7"
  },
  "build": {
    "appId": "com.electron-ai-framework.app",
    "productName": "Electron AI Framework",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "config/**/*"
    ]
  }
